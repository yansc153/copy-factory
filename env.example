COPY_FACTORY_ENV=local
COPY_FACTORY_DB=data/copy_factory.sqlite3
COPY_FACTORY_USER=admin
COPY_FACTORY_PASSWORD=password
COPY_FACTORY_SESSION_SECRET=dev-secret-change-me
COPY_FACTORY_SOURCES=mock-xueqiu,mock-reddit
COPY_FACTORY_PUBLISH_TOKEN=dev-publish-token
# Mac mini server-publish API auth. Prefer the file form in production.
# COPY_FACTORY_PUBLISH_TOKEN_FILE=/run/secrets/copy_factory_publish_token
COPY_FACTORY_SYNC_INTERVAL_SECONDS=1800

# Real latest-snapshot source.
# COPY_FACTORY_SOURCES=xueqiu,reddit
# NEWS_HARNESS_EXPORT_BASE_URL=https://newshardness.hellopepper.work
# NEWS_HARNESS_EXPORT_LIMIT=500
# COPY_FACTORY_IMPORT_SINCE=2026-06-20
# COPY_FACTORY_IMPORT_UNTIL=2026-06-21
# NEWS_HARNESS_EXPORT_TOKEN=
# NEWS_HARNESS_EXPORT_TOKEN_FILE=/run/secrets/news_harness_export_token

# Production writing requires one of these.
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_KEY_FILE=/run/secrets/deepseek_api_key
